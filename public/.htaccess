<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files/directories be served normally
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback: all app routes go to index.html
  RewriteRule . /index.html [L]
</IfModule>
